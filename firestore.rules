rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Anyone signed in (including anonymous) can read the job board and
    // settings, since this is a public marketplace.
    match /jobs/{jobId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      // Nobody deletes jobs directly from the client in this MVP.
      allow delete: if false;
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // A profile can only be created or edited by the user it belongs to.
    match /profiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
